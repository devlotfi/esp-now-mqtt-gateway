{
  "openapi": "3.0.0",
  "info": {
    "title": "ESP32 Management API",
    "description": "API for managing ESP32 device status, networking, ESP-NOW peers, notifications, and authentication.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "ESP32 Web Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string", "example": "INVALID_REQUEST" }
        }
      },
      "PasswordRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "password": { "type": "string" }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": { "type": "string" }
        }
      },
      "DeviceStatusResponse": {
        "type": "object",
        "properties": {
          "heap": {
            "type": "object",
            "properties": {
              "freeHeap": { "type": "integer" },
              "heapSize": { "type": "integer" },
              "minFreeHeap": { "type": "integer" },
              "maxAllocHeap": { "type": "integer" }
            }
          },
          "psram": {
            "type": "object",
            "properties": {
              "freePsram": { "type": "integer" },
              "psramSize": { "type": "integer" },
              "minFreePsram": { "type": "integer" },
              "maxAllocPsram": { "type": "integer" }
            }
          },
          "storage": {
            "type": "object",
            "properties": {
              "flashChipSize": { "type": "integer" },
              "freeSketchSpace": { "type": "integer" }
            }
          },
          "ethernet": {
            "type": "object",
            "properties": {
              "localIP": { "type": "string" },
              "macAddress": { "type": "string" },
              "linkUp": { "type": "boolean" },
              "linkSpeed": { "type": "integer" },
              "fullDuplex": { "type": "boolean" }
            }
          },
          "general": {
            "type": "object",
            "properties": {
              "uptime": { "type": "integer" },
              "cpuTemp": { "type": "number", "nullable": true }
            }
          }
        }
      },
      "NetworkIPRequest": {
        "type": "object",
        "required": ["ipAssignment"],
        "properties": {
          "ipAssignment": { "type": "string", "enum": ["DHCP", "STATIC"] },
          "staticConfig": {
            "type": "object",
            "properties": {
              "ip": { "type": "string" },
              "gateway": { "type": "string" },
              "subnet": { "type": "string" },
              "dns": { "type": "string" }
            }
          }
        }
      },
      "NotificationsConfigRequest": {
        "type": "object",
        "required": ["apiUrl", "apiSecret"],
        "properties": {
          "apiUrl": { "type": "string", "format": "uri" },
          "apiSecret": { "type": "string" }
        }
      },
      "SetMacRequest": {
        "type": "object",
        "required": ["mac"],
        "properties": {
          "mac": { "type": "string" }
        }
      },
      "SetPmkRequest": {
        "type": "object",
        "required": ["pmk"],
        "properties": {
          "pmk": { "type": "string" }
        }
      },
      "Peer": {
        "type": "object",
        "required": ["id", "name", "mac"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "mac": { "type": "string" }
        }
      },
      "PeersListResponse": {
        "type": "object",
        "required": ["peers"],
        "properties": {
          "peers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Peer" }
          }
        }
      },
      "AddPeerRequest": {
        "type": "object",
        "required": ["name", "mac", "lmk"],
        "properties": {
          "name": { "type": "string" },
          "mac": { "type": "string" },
          "lmk": { "type": "string" }
        }
      },
      "TopicItem": {
        "type": "object",
        "required": ["topic"],
        "properties": {
          "topic": { "type": "string" }
        }
      },
      "TopicListResponse": {
        "type": "object",
        "required": ["topicList"],
        "properties": {
          "topicList": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "UNAUTHORIZED" }
          }
        }
      },
      "NotFoundError": {
        "description": "Not Found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "NOT_FOUND" }
          }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PasswordRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginResponse" }
              }
            }
          },
          "400": { "description": "Invalid Request" },
          "403": {
            "description": "Wrong Password",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "WRONG_PASSWORD" }
              }
            }
          }
        }
      }
    },
    "/api/auth/set-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Update password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PasswordRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/api/device/reboot": {
      "get": {
        "tags": ["Device"],
        "summary": "Reboot the device",
        "responses": {
          "200": { "description": "Reboot initiated" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/api/device/status": {
      "get": {
        "tags": ["Device"],
        "summary": "Get device status and telemetry",
        "responses": {
          "200": {
            "description": "Device status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceStatusResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/api/network/ip": {
      "post": {
        "tags": ["Network"],
        "summary": "Configure IP assignment (DHCP/Static)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NetworkIPRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Network configured" },
          "400": { "description": "Invalid IP config or format" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/api/notifications": {
      "post": {
        "tags": ["Notifications"],
        "summary": "Configure webhook/API notifications",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NotificationsConfigRequest"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Configured" },
          "400": { "description": "Invalid URL or Request" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/api/notifications/test": {
      "post": {
        "tags": ["Notifications"],
        "summary": "Send a test notification",
        "responses": {
          "200": { "description": "Test sent" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/api/esp-now/set-mac": {
      "post": {
        "tags": ["ESP-NOW Configuration"],
        "summary": "Set custom MAC address",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SetMacRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "MAC address set" },
          "400": { "description": "Invalid MAC" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      }
    },
    "/api/esp-now/set-pmk": {
      "post": {
        "tags": ["ESP-NOW Configuration"],
        "summary": "Set Primary Master Key (PMK)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SetPmkRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "PMK set" },
          "400": { "description": "Invalid key" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "500": { "description": "ESP_NOW Error" }
        }
      }
    },
    "/api/esp-now/peers": {
      "get": {
        "tags": ["ESP-NOW Peers"],
        "summary": "List peers",
        "responses": {
          "200": {
            "description": "List",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PeersListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" }
        }
      },
      "post": {
        "tags": ["ESP-NOW Peers"],
        "summary": "Add peer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddPeerRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Added" },
          "400": { "description": "Invalid Request" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "description": "Duplicate" },
          "500": { "description": "Limit Reached" }
        }
      }
    },
    "/api/esp-now/peers/{id}": {
      "delete": {
        "tags": ["ESP-NOW Peers"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    },
    "/api/esp-now/topics/{id}": {
      "get": {
        "tags": ["ESP-NOW Topics"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Topics list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TopicListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      },
      "post": {
        "tags": ["ESP-NOW Topics"],
        "summary": "Add single topic",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TopicItem" }
            }
          }
        },
        "responses": {
          "200": { "description": "Topic added" },
          "400": { "description": "Invalid Request" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "403": { "description": "Topic exists" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "500": { "description": "Max topics" }
        }
      },
      "delete": {
        "tags": ["ESP-NOW Topics"],
        "summary": "Delete single topic",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TopicItem" }
            }
          }
        },
        "responses": {
          "200": { "description": "Topic deleted" },
          "400": { "description": "Invalid Request" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      }
    }
  }
}
