{
  "openapi": "3.0.0",
  "info": {
    "title": "ESP32 IoT Gateway API",
    "version": "1.0.0",
    "description": "API for managing ESP-NOW to MQTT gateway, network configurations, and device status."
  },
  "servers": [
    {
      "url": "http://{device_ip}/api",
      "variables": {
        "device_ip": {
          "default": "192.168.1.1"
        }
      }
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "INVALID_REQUEST"
          }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login to get JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" }
                  }
                }
              }
            }
          },
          "403": { "description": "Wrong password" }
        }
      }
    },
    "/auth/set-password": {
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Update device password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password updated" }
        }
      }
    },
    "/device/reboot": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Reboot the ESP32",
        "responses": {
          "200": { "description": "Device will restart" }
        }
      }
    },
    "/device/status": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Get system resources and network status",
        "responses": {
          "200": {
            "description": "System status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "heap": {
                      "type": "object",
                      "properties": {
                        "freeHeap": { "type": "integer" },
                        "heapSize": { "type": "integer" },
                        "minFreeHeap": { "type": "integer" },
                        "maxAllocHeap": { "type": "integer" }
                      }
                    },
                    "psram": {
                      "type": "object",
                      "properties": {
                        "freePsram": { "type": "integer" },
                        "psramSize": { "type": "integer" },
                        "minFreePsram": { "type": "integer" },
                        "maxAllocPsram": { "type": "integer" }
                      }
                    },
                    "storage": {
                      "type": "object",
                      "properties": {
                        "flashChipSize": { "type": "integer" },
                        "freeSketchSpace": { "type": "integer" }
                      }
                    },
                    "ethernet": {
                      "type": "object",
                      "properties": {
                        "mac": {
                          "type": "string",
                          "description": "Physical ETH MAC"
                        },
                        "localIP": { "type": "string" },
                        "macAddress": { "type": "string" },
                        "linkUp": { "type": "boolean" },
                        "linkSpeed": { "type": "integer" },
                        "fullDuplex": { "type": "boolean" }
                      }
                    },
                    "general": {
                      "type": "object",
                      "properties": {
                        "uptime": { "type": "integer" },
                        "mqttConnected": { "type": "boolean" },
                        "cpuTemp": { "type": "number", "nullable": true }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/esp-now/get-channel": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Get current WiFi channel",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "channel": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/esp-now/set-channel": {
      "post": {
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "channel": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Channel updated, device restarting" }
        }
      }
    },
    "/esp-now/set-pmk": {
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Set Primary Master Key",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pmk": {
                    "type": "string",
                    "description": "16-byte hex string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "PMK set" }
        }
      }
    },
    "/esp-now/peers": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "List all ESP-NOW peers",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "peers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string", "format": "uuid" },
                          "name": { "type": "string" },
                          "mac": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Add a new peer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "mac", "lmk"],
                "properties": {
                  "name": { "type": "string" },
                  "mac": { "type": "string" },
                  "lmk": { "type": "string", "description": "Local Master Key" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Peer added" },
          "403": { "description": "Peer already exists" }
        }
      }
    },
    "/esp-now/peers/{id}": {
      "delete": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Delete a peer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": { "description": "Peer deleted" },
          "404": { "description": "Peer not found" }
        }
      }
    },
    "/esp-now/topics/{id}": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Get topics for a peer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "topicList": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Add topic subscription",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "topic": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Topic added" }
        }
      },
      "delete": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Remove topic subscription",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "topic": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Topic removed" }
        }
      }
    },
    "/notifications": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Get notification settings",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "isSet": { "type": "boolean" },
                    "config": {
                      "type": "object",
                      "properties": {
                        "apiUrl": { "type": "string" },
                        "apiSecret": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Update notification settings",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "apiUrl": { "type": "string" },
                  "apiSecret": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Settings saved" }
        }
      }
    },
    "/notifications/test": {
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Trigger test notification",
        "responses": {
          "200": { "description": "Notification sent" }
        }
      }
    },
    "/mqtt": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Get MQTT config",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "isSet": { "type": "boolean" },
                    "config": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Set MQTT config",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["clientId", "url", "useAuth"],
                "properties": {
                  "clientId": { "type": "string" },
                  "url": { "type": "string" },
                  "useAuth": { "type": "boolean" },
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "MQTT settings saved" }
        }
      }
    },
    "/network": {
      "get": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Get IP settings",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ipAssignment": {
                      "type": "string",
                      "enum": ["DHCP", "STATIC"]
                    },
                    "ip": { "type": "string" },
                    "gateway": { "type": "string" },
                    "subnet": { "type": "string" },
                    "dns": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "security": [{ "bearerAuth": [] }],
        "summary": "Set IP settings",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ipAssignment"],
                "properties": {
                  "ipAssignment": {
                    "type": "string",
                    "enum": ["DHCP", "STATIC"]
                  },
                  "staticConfig": {
                    "type": "object",
                    "properties": {
                      "ip": { "type": "string" },
                      "gateway": { "type": "string" },
                      "subnet": { "type": "string" },
                      "dns": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Network settings saved" }
        }
      }
    }
  }
}
