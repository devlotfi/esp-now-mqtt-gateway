{
  "openapi": "3.0.3",
  "info": {
    "title": "ESP32 ESP-NOW REST API",
    "version": "1.0.0",
    "description": "API for managing ESP-NOW configuration, peers, and topics."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Health check / Index",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/login": {
      "post": {
        "summary": "Authenticate and receive a token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request (invalid JSON or missing password)"
          },
          "403": { "description": "Forbidden (incorrect password)" }
        }
      }
    },
    "/change-password": {
      "post": {
        "summary": "Change the authentication password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password changed successfully" },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/change-pmk": {
      "post": {
        "summary": "Change Primary Master Key (PMK)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["pmk"],
                "properties": {
                  "pmk": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "PMK changed successfully" },
          "400": { "description": "Bad request (invalid key format)" },
          "500": { "description": "Internal server error setting PMK" }
        }
      }
    },
    "/peers": {
      "get": {
        "summary": "List all configured peers",
        "responses": {
          "200": {
            "description": "A list of ESP-NOW peers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "peers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string" },
                          "name": { "type": "string" },
                          "mac": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new ESP-NOW peer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "mac", "lmk"],
                "properties": {
                  "name": { "type": "string" },
                  "mac": { "type": "string" },
                  "lmk": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Peer added successfully" },
          "400": { "description": "Bad request (invalid MAC or LMK)" },
          "403": {
            "description": "Forbidden (Peer name or MAC already exists)"
          },
          "500": {
            "description": "Server error (peer limit reached or ESP-NOW failure)"
          }
        }
      }
    },
    "/peers/{id}": {
      "delete": {
        "summary": "Delete a peer by ID",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "The UUID of the peer to delete"
          }
        ],
        "responses": {
          "200": { "description": "Peer deleted successfully" },
          "404": { "description": "Peer not found" }
        }
      }
    },
    "/peers/{id}/topics": {
      "get": {
        "summary": "Get the topic list for a specific peer",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "topicList": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Peer not found" }
        }
      },
      "post": {
        "summary": "Set the topic list for a specific peer",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["topicList"],
                "properties": {
                  "topicList": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Topic list updated" },
          "400": { "description": "Bad request (invalid array format)" },
          "404": { "description": "Peer not found" }
        }
      }
    }
  }
}
