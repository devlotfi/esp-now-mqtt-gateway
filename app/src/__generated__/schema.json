{
  "openapi": "3.0.0",
  "info": {
    "title": "ESP32 ESP-NOW Management API",
    "description": "API for managing ESP-NOW peers, topics, and authentication on an ESP32 device.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "ESP32 Web Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "PasswordRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "password": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT authentication token"
          }
        }
      },
      "SetPmkRequest": {
        "type": "object",
        "required": ["pmk"],
        "properties": {
          "pmk": {
            "type": "string",
            "description": "Primary Master Key (hex format)"
          }
        }
      },
      "Peer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "mac": {
            "type": "string"
          }
        }
      },
      "PeersListResponse": {
        "type": "object",
        "properties": {
          "peers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Peer"
            }
          }
        }
      },
      "AddPeerRequest": {
        "type": "object",
        "required": ["name", "mac", "lmk"],
        "properties": {
          "name": {
            "type": "string"
          },
          "mac": {
            "type": "string",
            "description": "Unicast MAC address"
          },
          "lmk": {
            "type": "string",
            "description": "Local Master Key (hex format)"
          }
        }
      },
      "TopicList": {
        "type": "object",
        "required": ["topicList"],
        "properties": {
          "topicList": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Authenticate and receive a JWT token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing or invalid password format"
          },
          "403": {
            "description": "Forbidden - Incorrect password"
          }
        }
      }
    },
    "/set-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Set a new authentication password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated successfully"
          },
          "400": {
            "description": "Bad Request - Missing or invalid password format"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid JWT token"
          }
        }
      }
    },
    "/set-pmk": {
      "post": {
        "tags": ["Configuration"],
        "summary": "Set the Primary Master Key (PMK) for ESP-NOW",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetPmkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PMK set successfully"
          },
          "400": {
            "description": "Bad Request - Missing or invalid PMK"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid JWT token"
          },
          "500": {
            "description": "Internal Server Error - Failed to set PMK in ESP-NOW"
          }
        }
      }
    },
    "/peers": {
      "get": {
        "tags": ["Peers"],
        "summary": "Get a list of all ESP-NOW peers",
        "responses": {
          "200": {
            "description": "List of peers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeersListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid JWT token"
          }
        }
      },
      "post": {
        "tags": ["Peers"],
        "summary": "Add a new ESP-NOW peer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddPeerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Peer added successfully"
          },
          "400": {
            "description": "Bad Request - Missing fields, invalid keys, or invalid MAC address"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid JWT token"
          },
          "403": {
            "description": "Forbidden - Peer with the same name or MAC already exists"
          },
          "500": {
            "description": "Internal Server Error - Peer list full or ESP-NOW add failed"
          }
        }
      }
    },
    "/peers/{id}": {
      "delete": {
        "tags": ["Peers"],
        "summary": "Delete an ESP-NOW peer by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of the peer",
            "schema": {
              "type": "string",
              "format": "uuid",
              "pattern": "^[0-9a-fA-F-]{36}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Peer deleted successfully"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid JWT token"
          },
          "404": {
            "description": "Not Found - Peer with the specified ID does not exist"
          }
        }
      }
    },
    "/topics/{id}": {
      "get": {
        "tags": ["Topics"],
        "summary": "Get topics associated with a specific peer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of the peer",
            "schema": {
              "type": "string",
              "format": "uuid",
              "pattern": "^[0-9a-fA-F-]{36}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of topics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TopicList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid JWT token"
          },
          "404": {
            "description": "Not Found - Peer with the specified ID does not exist"
          }
        }
      },
      "post": {
        "tags": ["Topics"],
        "summary": "Set topics for a specific peer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of the peer",
            "schema": {
              "type": "string",
              "format": "uuid",
              "pattern": "^[0-9a-fA-F-]{36}$"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TopicList"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Topics set successfully"
          },
          "400": {
            "description": "Bad Request - Invalid payload format (array must contain only strings)"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid JWT token"
          },
          "404": {
            "description": "Not Found - Peer with the specified ID does not exist"
          }
        }
      }
    }
  }
}
